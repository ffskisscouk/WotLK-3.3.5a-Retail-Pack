<Ui xmlns="http://www.blizzard.com/wow/ui/"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

  <!-- ====================================================================
       UnitFrame Layers XML Templates
       Ported from UnitFrameLayers addon for DragonUI integration.
       Provides heal prediction, absorb shield, and animated loss templates.
       ==================================================================== -->

  <!-- Texture templates (virtual) -->
  <Texture name="DragonUI_MyHealPredictionBarTemplate" virtual="true" file="Interface\TargetingFrame\UI-StatusBar">
    <Color r="0.0" g="0.827" b="0.765"/>
  </Texture>
  <Texture name="DragonUI_MyManaCostPredictionBarTemplate" virtual="true" file="Interface\TargetingFrame\UI-StatusBar">
    <Color r="0.0" g="0.447" b="1.0"/>
  </Texture>
  <Texture name="DragonUI_OtherHealPredictionBarTemplate" virtual="true" file="Interface\TargetingFrame\UI-StatusBar">
    <Color r="0.0" g="0.631" b="0.557"/>
  </Texture>
  <Texture name="DragonUI_TotalAbsorbBarTemplate" virtual="true" file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\Shield-Fill"/>
  <Texture name="DragonUI_HealAbsorbBarTemplate" virtual="true"/>
  <Texture name="DragonUI_HealAbsorbBarLeftShadowTemplate" virtual="true" file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\Absorb-Edge"/>
  <Texture name="DragonUI_HealAbsorbBarRightShadowTemplate" virtual="true" file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\Absorb-Edge">
    <TexCoords left="1" right="0" top="0" bottom="1"/>
  </Texture>

  <Texture name="DragonUI_TotalAbsorbBarOverlayTemplate" virtual="true" file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\Shield-Overlay" vertTile="true" horizTile="true"/>
  <Texture name="DragonUI_OverAbsorbGlowTemplate" virtual="true" file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\Shield-Overshield" alphaMode="ADD">
    <Size x="16" y="0"/>
  </Texture>
  <Texture name="DragonUI_OverHealAbsorbGlowTemplate" virtual="true" file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\Absorb-Overabsorb" alphaMode="ADD">
    <Size x="16" y="0"/>
  </Texture>

  <!-- Main heal prediction container template -->
  <Frame name="DragonUI_StatusBarHealPredictionTemplate" frameLevel="1" setAllPoints="true" virtual="true">
    <Layers>
      <Layer level="BORDER">
        <Texture name="$parentOverHealAbsorbGlow" inherits="DragonUI_OverHealAbsorbGlowTemplate"/>
        <Texture name="$parentHealAbsorbBar" inherits="DragonUI_HealAbsorbBarTemplate"/>
        <Texture name="$parentFrameMyHealPredictionBar" inherits="DragonUI_MyHealPredictionBarTemplate"/>
        <Texture name="$parentFrameOtherHealPredictionBar" inherits="DragonUI_OtherHealPredictionBarTemplate"/>
        <Texture name="$parentFrameManaCostPredictionBar" inherits="DragonUI_MyManaCostPredictionBarTemplate"/>
      </Layer>
      <Layer level="ARTWORK">
        <Texture name="$parentTotalAbsorbBar" inherits="DragonUI_TotalAbsorbBarTemplate"/>
        <Texture name="$parentHealAbsorbBarRightShadow" inherits="DragonUI_HealAbsorbBarRightShadowTemplate"/>
        <Texture name="$parentHealAbsorbBarLeftShadow" inherits="DragonUI_HealAbsorbBarLeftShadowTemplate"/>
        <Texture name="$parentTotalAbsorbBarOverlay" inherits="DragonUI_TotalAbsorbBarOverlayTemplate"/>
      </Layer>
    </Layers>
    <Frames setAllPoints="true">
      <Frame name="$parentFrameOverAbsorb" frameLevel="3">
        <Layers>
          <Layer level="OVERLAY">
            <Texture name="$parentGlow" inherits="DragonUI_OverAbsorbGlowTemplate"/>
          </Layer>
        </Layers>
      </Frame>
    </Frames>
  </Frame>

  <!-- Animated health loss bar template (player only) -->
  <StatusBar name="DragonUI_PlayerFrameHealthBarAnimatedLossTemplate" hidden="true" virtual="true">
    <BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
    <Scripts>
      <OnLoad>
        DragonUI_Mixin(self, DragonUI_AnimatedHealthLossMixin);
        self:OnLoad();
      </OnLoad>
    </Scripts>
  </StatusBar>

  <!-- Builder/Spender feedback frame template -->
  <Frame name="DragonUI_BuilderSpenderFrame" virtual="true">
    <Layers>
      <Layer level="ARTWORK">
        <Texture parentKey="BarTexture" file="Interface\TargetingFrame\UI-StatusBar" hidden="true"/>
      </Layer>
      <Layer level="OVERLAY">
        <Texture file="Interface\TargetingFrame\UI-StatusBar-Glow" parentKey="LossGlowTexture" hidden="true" alphaMode="ADD"/>
      </Layer>
      <Layer level="OVERLAY">
        <Texture file="Interface\TargetingFrame\UI-StatusBar-Glow" parentKey="GainGlowTexture" hidden="true" alphaMode="ADD" alpha="0.75"/>
      </Layer>
    </Layers>
    <Scripts>
      <OnLoad>
        DragonUI_Mixin(self, DragonUI_BuilderSpender);
        self:OnLoad();
      </OnLoad>
    </Scripts>
  </Frame>

  <!-- Full resource pulse frame template -->
  <Frame name="DragonUI_FullResourcePulseFrame" virtual="true">
    <Size x="119" y="12"/>
    <Scripts>
      <OnLoad>
        DragonUI_Mixin(self, DragonUI_FullResourcePulse);
      </OnLoad>
    </Scripts>
    <Frames>
      <Frame parentKey="SpikeFrame">
        <Size x="119" y="12"/>
        <Anchors>
          <Anchor point="TOPRIGHT"/>
        </Anchors>
        <Layers>
          <Layer level="OVERLAY">
            <Texture file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\PlayerFrameFX" parentKey="BigSpikeGlow" alpha="0" alphaMode="BLEND">
              <Size x="27" y="34"/>
              <TexCoords left="0.0078125" right="0.21875" top="0.015625" bottom="0.546875"/>
              <Anchors>
                <Anchor point="RIGHT" x="21" y="0"/>
              </Anchors>
              <Animations>
                <AnimationGroup parentKey="SpikeAnim" setToFinalAlpha="true">
                  <Alpha childKey="BigSpikeGlow" smoothing="IN" duration="0.25" order="1" change="1"/>
                  <Scale childKey="BigSpikeGlow" smoothing="NONE" duration="0" order="1" scaleX="0.25" scaleY="0.25"/>
                  <Scale childKey="BigSpikeGlow" smoothing="NONE" duration="0.1" order="1" scaleX="1.5" scaleY="1.5">
                    <Origin point="LEFT">
                      <Offset x="2" y="0"/>
                    </Origin>
                  </Scale>
                  <Scale childKey="BigSpikeGlow" startDelay="0.2" smoothing="IN" duration="0.2" order="1" scaleX="0.5" scaleY="0.5">
                    <Origin point="LEFT">
                      <Offset x="6" y="0"/>
                    </Origin>
                  </Scale>
                  <Alpha childKey="BigSpikeGlow" startDelay="0.3" duration="0" order="1" change="1"/>
                  <Alpha childKey="BigSpikeGlow" startDelay="0.3" duration="0.25" order="1" change="-1"/>
                </AnimationGroup>
              </Animations>
            </Texture>
            <Texture file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\PlayerFrameFX" parentKey="AlertSpikeStay" alpha="0" alphaMode="BLEND">
              <Size x="34" y="18"/>
              <TexCoords left="0.578125" right="0.84375" top="0.015625" bottom="0.296875"/>
              <Anchors>
                <Anchor point="RIGHT" x="11" y="0"/>
              </Anchors>
              <Animations>
                <AnimationGroup parentKey="SpikeAnim" setToFinalAlpha="true">
                  <Alpha name="Spikey" childKey="AlertSpikeStay" smoothing="IN" duration="0.25" order="1" change="1"/>
                </AnimationGroup>
              </Animations>
            </Texture>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
              local SpikeFrame = self;
              self.SpikeAnim = {};
              self.SpikeAnim.Play = function()
                  SpikeFrame.BigSpikeGlow.SpikeAnim:Play();
                  SpikeFrame.AlertSpikeStay.SpikeAnim:Play();
              end
              self.SpikeAnim.Stop = function()
                  SpikeFrame.BigSpikeGlow.SpikeAnim:Stop();
                  SpikeFrame.AlertSpikeStay.SpikeAnim:Stop();
              end
              self.SpikeAnim.IsPlaying = function()
                  local a = SpikeFrame.BigSpikeGlow.SpikeAnim:IsPlaying();
                  local b = SpikeFrame.AlertSpikeStay.SpikeAnim:IsPlaying();
                  return a or b;
              end
          </OnLoad>
        </Scripts>
      </Frame>
      <Frame parentKey="PulseFrame">
        <Size x="119" y="12"/>
        <Anchors>
          <Anchor point="TOPRIGHT"/>
        </Anchors>
        <Layers>
          <Layer level="OVERLAY">
            <Texture file="Interface\AddOns\DragonUI\Textures\UnitFrameLayers\PlayerFrameFX" parentKey="PulseGlow" alpha="0" alphaMode="ADD">
              <TexCoords left="0.0078125" right="0.9375" top="0.546875" bottom="1.0"/>
              <Anchors>
                <Anchor point="TOPRIGHT"/>
              </Anchors>
              <Animations>
                <AnimationGroup parentKey="PulseAnim" setToFinalAlpha="true">
                  <Alpha childKey="PulseGlow" smoothing="IN" duration="0.2" order="1" change="0.6"/>
                  <Alpha childKey="PulseGlow" startDelay="0.1" smoothing="OUT" duration="0.3" order="1" change="-0.6"/>
                </AnimationGroup>
              </Animations>
            </Texture>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
              local PulseFrame = self;
              self.PulseAnim = {};
              self.PulseAnim.Play = function()
                  PulseFrame.PulseGlow.PulseAnim:Play();
              end
              self.PulseAnim.Stop = function()
                  PulseFrame.PulseGlow.PulseAnim:Stop();
              end
              self.PulseAnim.IsPlaying = function()
                  return PulseFrame.PulseGlow.PulseAnim:IsPlaying();
              end
          </OnLoad>
        </Scripts>
      </Frame>
    </Frames>
  </Frame>

  <!-- Full power frame (anchored version) -->
  <Frame name="DragonUI_FullPowerFrameTemplate" inherits="DragonUI_FullResourcePulseFrame" virtual="true">
    <Size x="119" y="12"/>
    <Anchors>
      <Anchor point="TOPRIGHT"/>
    </Anchors>
  </Frame>

</Ui>
