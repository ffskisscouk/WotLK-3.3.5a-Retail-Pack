<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Script file="src\frames\configFrame\config.frame.lua" />
    
    <!-- EditBox Template for Config -->
    <EditBox name="DConfigEditBoxTemplate" virtual="true" letters="5">
        <Size>
            <AbsDimension x="80" y="25" />
        </Size>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parentBG" file="Interface\AddOns\DialogUI\src\assets\art\parchment\ButtonHighlight-Gossip">
                    <Size>
                        <AbsDimension x="80" y="25" />
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER" />
                    </Anchors>
                    <Color>
                        <Color r="0.9" g="0.9" b="0.8" a="0.9" />
                    </Color>
                </Texture>
            </Layer>
        </Layers>
        <FontString inherits="DQuestButtonTitleGossip" />
        <Scripts>
            <OnLoad>
                this:SetAutoFocus(false);
                this:SetNumeric(false);
            </OnLoad>
            <OnEscapePressed>
                this:ClearFocus();
            </OnEscapePressed>
        </Scripts>
    </EditBox>

    <!-- Font Button Template -->
    <Button name="DConfigFontButtonTemplate" virtual="true">
        <Size>
            <AbsDimension x="110" y="28" />
        </Size>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parentBackground" file="Interface\AddOns\DialogUI\src\assets\art\parchment\OptionBackground-common">
                    <Size>
                        <AbsDimension x="110" y="28" />
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER" />
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <!-- Галочка для выбранного шрифта -->
                <Texture name="$parentCheck" file="Interface\Buttons\UI-CheckBox-Check" hidden="true">
                    <Size>
                        <AbsDimension x="16" y="16" />
                    </Size>
                    <Anchors>
                        <Anchor point="LEFT">
                            <Offset>
                                <AbsDimension x="5" y="0" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="$parentText" inherits="DQuestButtonTitleGossip" justifyH="CENTER">
                    <Size>
                        <AbsDimension x="90" y="20" />
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER">
                            <Offset>
                                <AbsDimension x="5" y="0" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <HighlightTexture file="Interface\AddOns\DialogUI\src\assets\art\parchment\ButtonHighlight-Gossip" alphaMode="ADD" />
    </Button>

    <!-- Main Config Frame -->
    <Frame name="DConfigFrame" toplevel="true" parent="UIParent" movable="false" enableMouse="true" hidden="true">
        <Size>
            <AbsDimension x="480" y="600" />
        </Size>
        <Anchors>
            <Anchor point="CENTER" />
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture file="Interface\AddOns\DialogUI\src\assets\art\parchment\Parchment">
                    <Size x="480" y="600" />
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="DConfigFrameTitle" inherits="DQuestTitleFont" text="Settings DialogUI" justifyH="CENTER">
                    <Size>
                        <AbsDimension x="430" y="25"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset>
                                <AbsDimension x="0" y="-30" />
                            </Offset>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <!-- Scroll Frame for scrollable content -->
            <ScrollFrame name="DConfigScrollFrame" inherits="UIPanelScrollFrameTemplate">
                <Size>
                    <AbsDimension x="430" y="440" />
                </Size>
                <Anchors>
                    <Anchor point="TOP" relativeTo="DConfigFrameTitle" relativePoint="BOTTOM">
                        <Offset>
                            <AbsDimension x="0" y="-20" />
                        </Offset>
                    </Anchor>
                </Anchors>
                <ScrollChild>
                    <Frame name="DConfigScrollChild">
                        <Size>
                            <AbsDimension x="400" y="1000" />
                        </Size>
                        <Layers>
                            <Layer level="ARTWORK">
                                <!-- Information Text -->
                                <FontString name="DConfigInfoText" inherits="DQuestFont" justifyH="LEFT" justifyV="TOP">
                                    <Size>
                                        <AbsDimension x="380" y="240"/>
                                    </Size>
                                    <Anchors>
                                        <Anchor point="TOP">
                                            <Offset>
                                                <AbsDimension x="0" y="-10" />
                                            </Offset>
                                        </Anchor>
                                    </Anchors>
                                </FontString>
                                
                                <!-- Scale Label -->
                                <FontString name="DConfigScaleLabel" inherits="DQuestButtonTitleGossip" text="Scale:" justifyH="LEFT">
                                    <Size>
                                        <AbsDimension x="345" y="20" />
                                    </Size>
                                    <Anchors>
                                        <Anchor point="TOPLEFT" relativeTo="DConfigInfoText" relativePoint="BOTTOMLEFT">
                                            <Offset>
                                                <AbsDimension x="0" y="-20" />
                                            </Offset>
                                        </Anchor>
                                    </Anchors>
                                </FontString>
                                
                                <!-- Transparency Label -->
                                <FontString name="DConfigAlphaLabel" inherits="DQuestButtonTitleGossip" text="Transparency:" justifyH="LEFT">
                                    <Size>
                                        <AbsDimension x="345" y="20" />
                                    </Size>
                                    <Anchors>
                                        <Anchor point="TOPLEFT" relativeTo="DConfigScaleLabel" relativePoint="BOTTOMLEFT">
                                            <Offset>
                                                <AbsDimension x="0" y="-35" />
                                            </Offset>
                                        </Anchor>
                                    </Anchors>
                                </FontString>
                                
                                <!-- Font Size Label -->
                                <FontString name="DConfigFontLabel" inherits="DQuestButtonTitleGossip" text="Font size:" justifyH="LEFT">
                                    <Size>
                                        <AbsDimension x="345" y="20" />
                                    </Size>
                                    <Anchors>
                                        <Anchor point="TOPLEFT" relativeTo="DConfigAlphaLabel" relativePoint="BOTTOMLEFT">
                                            <Offset>
                                                <AbsDimension x="0" y="-35" />
                                            </Offset>
                                        </Anchor>
                                    </Anchors>
                                </FontString>

                                <!-- Font Select Label -->
                                <FontString name="DConfigFontSelectLabel" inherits="DQuestButtonTitleGossip" text="Font:" justifyH="LEFT">
                                    <Size>
                                        <AbsDimension x="345" y="20" />
                                    </Size>
                                    <Anchors>
                                        <Anchor point="TOPLEFT" relativeTo="DConfigFontLabel" relativePoint="BOTTOMLEFT">
                                            <Offset>
                                                <AbsDimension x="0" y="-35" />
                                            </Offset>
                                        </Anchor>
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                        <Frames>
                            <!-- Scale EditBox -->
                            <EditBox name="DConfigScaleEditBox" inherits="DConfigEditBoxTemplate">
                                <Anchors>
                                    <Anchor point="LEFT" relativeTo="DConfigScaleLabel" relativePoint="RIGHT">
                                        <Offset>
                                            <AbsDimension x="10" y="0" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnEnterPressed>
                                        DConfigScaleEditBox_OnEnterPressed();
                                    </OnEnterPressed>
                                </Scripts>
                            </EditBox>

                            <!-- Transparency EditBox -->
                            <EditBox name="DConfigAlphaEditBox" inherits="DConfigEditBoxTemplate">
                                <Anchors>
                                    <Anchor point="LEFT" relativeTo="DConfigAlphaLabel" relativePoint="RIGHT">
                                        <Offset>
                                            <AbsDimension x="10" y="0" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnEnterPressed>
                                        DConfigAlphaEditBox_OnEnterPressed();
                                    </OnEnterPressed>
                                </Scripts>
                            </EditBox>

                            <!-- Font Size EditBox -->
                            <EditBox name="DConfigFontEditBox" inherits="DConfigEditBoxTemplate">
                                <Anchors>
                                    <Anchor point="LEFT" relativeTo="DConfigFontLabel" relativePoint="RIGHT">
                                        <Offset>
                                            <AbsDimension x="10" y="0" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnEnterPressed>
                                        DConfigFontEditBox_OnEnterPressed();
                                    </OnEnterPressed>
                                </Scripts>
                            </EditBox>

                            <!-- Font Selection Buttons - First Row -->
                            <Button name="DConfigFontButton1" inherits="DConfigFontButtonTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" relativeTo="DConfigFontSelectLabel" relativePoint="BOTTOMLEFT">
                                        <Offset>
                                            <AbsDimension x="0" y="-15" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnClick>
                                        DConfigFontButton_OnClick(1);
                                    </OnClick>
                                </Scripts>
                            </Button>

                            <Button name="DConfigFontButton2" inherits="DConfigFontButtonTemplate">
                                <Anchors>
                                    <Anchor point="LEFT" relativeTo="DConfigFontButton1" relativePoint="RIGHT">
                                        <Offset>
                                            <AbsDimension x="10" y="0" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnClick>
                                        DConfigFontButton_OnClick(2);
                                    </OnClick>
                                </Scripts>
                            </Button>

                            <!-- Font Selection Buttons - Second Row -->
                            <Button name="DConfigFontButton3" inherits="DConfigFontButtonTemplate">
                                <Anchors>
                                    <Anchor point="TOPLEFT" relativeTo="DConfigFontButton1" relativePoint="BOTTOMLEFT">
                                        <Offset>
                                            <AbsDimension x="0" y="-10" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnClick>
                                        DConfigFontButton_OnClick(3);
                                    </OnClick>
                                </Scripts>
                            </Button>

                            <Button name="DConfigFontButton4" inherits="DConfigFontButtonTemplate">
                                <Anchors>
                                    <Anchor point="LEFT" relativeTo="DConfigFontButton3" relativePoint="RIGHT">
                                        <Offset>
                                            <AbsDimension x="10" y="0" />
                                        </Offset>
                                    </Anchor>
                                </Anchors>
                                <Scripts>
                                    <OnClick>
                                        DConfigFontButton_OnClick(4);
                                    </OnClick>
                                </Scripts>
                            </Button>
                        </Frames>
                    </Frame>
                </ScrollChild>
            </ScrollFrame>
            
            <!-- Fixed buttons outside scroll area -->
            <Button name="DConfigResetButton" inherits="DUIPanelButtonTemplate" text="Reset">
                <Size>
                    <AbsDimension x="180" y="35" />
                </Size>
                <Anchors>
                    <Anchor point="BOTTOM">
                        <Offset>
                            <AbsDimension x="-90" y="50" />
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>
                        DConfigResetButton_OnClick();
                    </OnClick>
                </Scripts>
            </Button>

            <Button name="DConfigCloseButton" inherits="DUIPanelButtonTemplate" text="Close">
                <Size>
                    <AbsDimension x="180" y="35" />
                </Size>
                <Anchors>
                    <Anchor point="BOTTOM">
                        <Offset>
                            <AbsDimension x="90" y="50" />
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>
                        DConfigCloseButton_OnClick();
                    </OnClick>
                </Scripts>
            </Button>
        </Frames>
        <Scripts>
            <OnLoad>
                DConfigFrame_OnLoad(self);
            </OnLoad>
            <OnShow>
                DConfigFrame_OnShow(self);
            </OnShow>
            <OnHide>
                DConfigFrame_OnHide(self);
            </OnHide>
        </Scripts>
    </Frame>
</Ui>
